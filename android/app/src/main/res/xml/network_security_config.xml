<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows plaintext HTTP to the local Django dev server only. Remove this
  domain entry once the backend is served over HTTPS / has a real host.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.0.113</domain>
    </domain-config>
</network-security-config>
